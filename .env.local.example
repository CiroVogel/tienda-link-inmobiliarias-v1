# ─── Auth local para desarrollo sin OAuth de Manus ───────────────────────────
# Copiá este archivo como .env y completá los valores

# Activa el login local (email+password) en lugar de Manus OAuth
LOCAL_AUTH_ENABLED=true
VITE_LOCAL_AUTH_ENABLED=true

# Credenciales del admin local — cambiá por las tuyas
ADMIN_EMAIL=admin@inmobiliarias.local
ADMIN_PASSWORD=Admin12345!

# ─── Base de datos ────────────────────────────────────────────────────────────
# Cadena de conexión MySQL local o remota
DATABASE_URL=mysql://usuario:password@localhost:3306/mini_web_servicios

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Clave para firmar las cookies de sesión — cualquier string largo y aleatorio
JWT_SECRET=cambia-esto-por-un-string-largo-y-aleatorio

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Token de prueba (TEST-) o producción (APP_USR-)
MERCADO_PAGO_ACCESS_TOKEN=TEST-tu-token-aqui

# ─── Variables de Manus OAuth (no necesarias con LOCAL_AUTH_ENABLED=true) ────
# Dejar vacías o comentadas en modo local
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# VITE_GA4_ID=G-XXXXXXXXXX
# VITE_META_PIXEL_ID=123456789012345

# ─── Storage de Manus (no necesario para desarrollo básico) ──────────────────
# Sin estas variables, la subida de imágenes falla pero el resto funciona
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# Meta WhatsApp Cloud API (produccion)
# WHATSAPP_META_ACCESS_TOKEN=
# WHATSAPP_META_PHONE_NUMBER_ID=
# WHATSAPP_META_API_BASE_URL=https://graph.facebook.com
# WHATSAPP_META_GRAPH_VERSION=v23.0
# WHATSAPP_META_TEMPLATE_LANGUAGE_CODE=es_AR
# WHATSAPP_META_CLIENT_PAYMENT_TEMPLATE_NAME=
# WHATSAPP_META_OWNER_PAYMENT_TEMPLATE_NAME=
